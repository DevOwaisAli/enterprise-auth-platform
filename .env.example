# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api
API_DEFAULT_VERSION=1
CORS_ORIGIN=*
BODY_LIMIT=10mb
APP_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/enterprise_auth?schema=public
DATABASE_LOG_QUERIES=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=enterprise-auth-platform
JWT_AUDIENCE=enterprise-auth-platform-clients

# Auth
BCRYPT_SALT_ROUNDS=12
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_HISTORY_LIMIT=5
MAX_LOGIN_ATTEMPTS=5
LOCK_DURATION_MS=900000
EMAIL_VERIFICATION_TOKEN_TTL_MS=86400000
PASSWORD_RESET_TOKEN_TTL_MS=3600000
SESSION_TTL_MS=604800000

# Mail (SMTP)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=no-reply@example.com
MAIL_FROM_NAME=Enterprise Auth Platform

# Queue (BullMQ) — uses Redis above by default; override here if needed
QUEUE_PREFIX=eap
QUEUE_DEFAULT_ATTEMPTS=3
QUEUE_DEFAULT_BACKOFF_MS=5000

# Throttling / rate-limit defaults
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# Swagger / OpenAPI
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs
SWAGGER_TITLE=Enterprise Auth Platform API
SWAGGER_DESCRIPTION=Enterprise-grade authentication and authorization platform
SWAGGER_VERSION=0.2.0

# Logger
LOG_LEVEL=debug
LOG_PRETTY=true

# Identity Federation (MFA / OAuth / SAML SSO)
# REQUIRED in production: 32+ char key used to encrypt MFA secrets, OAuth tokens, and SAML certs (AES-256-GCM)
FEDERATION_ENCRYPTION_KEY=change-me-federation-encryption-key-32chars
MFA_ISSUER=EnterpriseAuthPlatform
MFA_CHALLENGE_TTL_MS=300000
MFA_CHALLENGE_TOKEN_BYTES=32
MFA_BACKUP_CODE_COUNT=10
MFA_TOTP_WINDOW=1
OAUTH_STATE_TTL_MS=600000

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=

# GitHub OAuth
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CALLBACK_URL=

# Microsoft / Azure AD OAuth
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CALLBACK_URL=
MICROSOFT_OAUTH_TENANT_ID=common

# SAML SSO (service provider settings)
SAML_ENTITY_ID=urn:enterprise-auth-platform:sp
SAML_ACS_BASE_URL=
SAML_CLOCK_SKEW_MS=300000
SAML_REPLAY_CACHE_TTL_MS=3600000
